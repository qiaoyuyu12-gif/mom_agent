# ================== 应用 ==================
APP_HOST=0.0.0.0
APP_PORT=8000

# ================== vLLM (Qwen3) ==================
# vLLM OpenAI 兼容端点,例如 http://192.168.1.10:8000/v1
# 该段是默认的本地推理模型;若想改用第三方 API,见下方 "通用 LLM" 段。
VLLM_BASE_URL=http://localhost:8001/v1
VLLM_API_KEY=EMPTY
# 在 vLLM 启动时使用的模型名(与 --served-model-name 一致)
VLLM_MODEL=Qwen3
# 生成参数
VLLM_TEMPERATURE=0.3
VLLM_MAX_TOKENS=2048

# ================== 通用 LLM(支持第三方 OpenAI 兼容 API) ==================
# 这一段是「可选覆盖」:留空则继续走上面 VLLM_* 配置,完全向后兼容。
# provider 取值:
#   vllm   —— 本地 vLLM(默认),会注入 Qwen3 的 enable_thinking 开关
#   openai —— 任意 OpenAI 兼容第三方(DeepSeek/Moonshot/DashScope/智谱/OpenAI 等)
LLM_PROVIDER=vllm
# 留空则回退到 VLLM_BASE_URL 等。下面四行示例了几家常见第三方 API:
#   DeepSeek :  LLM_BASE_URL=https://api.deepseek.com/v1   LLM_MODEL=deepseek-chat
#   Moonshot :  LLM_BASE_URL=https://api.moonshot.cn/v1     LLM_MODEL=moonshot-v1-32k
#   DashScope:  LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#               LLM_MODEL=qwen-plus
#   OpenAI   :  LLM_BASE_URL=https://api.openai.com/v1      LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TEMPERATURE=
LLM_MAX_TOKENS=
# 是否仍然附加 Qwen3 的 chat_template_kwargs.enable_thinking(留空按 provider 自动判定:
# vllm=true,其它=false)。第三方 API 多数不识别此参数,请勿手动开启。
LLM_ENABLE_THINKING_PARAM=
# 透传给底层 OpenAI 客户端的额外参数(JSON),用于供应商专属字段。
# 例:OpenAI o 系列推理强度  LLM_EXTRA_BODY_JSON={"reasoning_effort":"medium"}
LLM_EXTRA_BODY_JSON=

# ================== RAGFlow ==================
RAGFLOW_BASE_URL=http://localhost:9380
RAGFLOW_API_KEY=ragflow-xxxxxx
# 知识库 dataset_id,多个用逗号分隔
RAGFLOW_DATASET_IDS=
RAGFLOW_TOP_K=6
RAGFLOW_SIMILARITY_THRESHOLD=0.2
RAGFLOW_VECTOR_WEIGHT=0.3

# ================== Redis (短期记忆) ==================
REDIS_URL=redis://localhost:6379/0
# 单会话 TTL,单位秒,默认 7 天
REDIS_TTL_SECONDS=604800

# ================== PostgreSQL (长期记忆) ==================
# 注意:宿主机端口为 5433(compose 已映射 5433->5432,避开本机已占用的 5432)
DATABASE_URL=postgresql+psycopg2://mom:mom@localhost:5433/mom_agent

# ================== 上下文压缩(SummarizationMiddleware) ==================
# 触发摘要前允许的最大 token 数;超过即触发 LangChain 内部摘要
MAX_HISTORY_TOKENS=3000
# 触发摘要后保留多少条最新消息(其余进入摘要)
KEEP_RECENT_MESSAGES=6

# ================== 模型调用次数限制(ModelCallLimitMiddleware) ==================
# 单次 /chat 请求最多调用模型多少次(无工具时通常 1 次足矣)
MODEL_CALL_RUN_LIMIT=4
# 一个 session(thread)累计最多调用模型多少次,达到后 agent 提前结束
MODEL_CALL_THREAD_LIMIT=200

# ================== Skill ==================
SKILLS_DIR=./skills
